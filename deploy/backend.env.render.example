# =============================================================
#  RankScript — Backend environment variables for Render
#  Set these in: Render Dashboard -> rankscript-backend -> Environment
#  Do NOT commit real values. This file is a reference only.
# =============================================================

# --- From Neon (Database) -------------------------------------
# Dashboard -> your project -> Connection Details -> "Pooled connection"
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/rankscript?sslmode=require

# --- From Upstash (Redis) --------------------------------------
# Dashboard -> your database -> "Connect" -> copy the rediss:// URL
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# --- Auth -------------------------------------------------------
# Generate locally with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---------------------------------------------------
# Your Vercel frontend URL, no trailing slash
ALLOWED_ORIGINS=https://rankscript.vercel.app

# --- App ------------------------------------------------------
ENVIRONMENT=production
DEBUG=False
