# =============================================================
#  RankScript — Frontend environment variables for Vercel
#  Set these in: Vercel Dashboard -> rankscript -> Settings -> Environment Variables
#  Do NOT commit real values. This file is a reference only.
# =============================================================

# Your live Render backend URL (no trailing slash).
# Used server-side by next.config.js to proxy /api/* requests.
BACKEND_INTERNAL_URL=https://rankscript-backend.onrender.com

# Optional: only needed if any client-side code reads this directly
# (the axios instance uses the same-origin "/api" path by default, so
# this is mainly a fallback / for reference).
NEXT_PUBLIC_API_URL=https://rankscript-backend.onrender.com
NEXT_PUBLIC_APP_NAME=RankScript
