# =============================================
#   RankScript — Environment Variables Template
#   Copy this file to .env and fill in your values
#
#   IMPORTANT: Never commit .env to version control.
#   Generate a SECRET_KEY with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# =============================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=rankscript
DATABASE_URL=postgresql://postgres:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/rankscript

# Redis
REDIS_URL=redis://redis:6379/0
# Set a password and update docker-compose.yml redis command to:
#   redis-server /usr/local/etc/redis/redis.conf --requirepass ${REDIS_PASSWORD}
REDIS_PASSWORD=

# JWT — MUST be a cryptographically random string in production
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=False
ENVIRONMENT=production
ALLOWED_ORIGINS=https://yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RankScript

# Optional: Google OAuth (uncomment if needed)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# pgAdmin (optional — only used with: docker-compose --profile tools up)
PGADMIN_EMAIL=admin@rankscript.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
